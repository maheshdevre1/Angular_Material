// Reverse a String (Without inbuilt methods)
// ✅Reverse a string without using reverse().
function reverseString(str) {
    let result = "";
    
    for (let i = str.length - 1; i >= 0; i--) {
        result = result + str[i];
    }
    
    return result;
}

