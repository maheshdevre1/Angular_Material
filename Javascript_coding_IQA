// 🔹 3. Find Largest Number in Array
// Find the largest number without Math.max().

function findMax(arr) {
    let max = arr[0];

    for (let i = 1; i < arr.length; i++) {
        if (arr[i] > max) {
            max = arr[i];
        }
    }

    return max;
}

