//4. Remove Duplicates from Array

function removeDuplicates(arr) {
    let result = [];

    for (let i = 0; i < arr.length; i++) {
        let found = false;

        for (let j = 0; j < result.length; j++) {
            if (arr[i] === result[j]) {
                found = true;
                break;
            }
        }

        if (!found) {
            result[result.length] = arr[i];
        }
    }

    return result;
}

//5. Count Frequency of Characters

function charFrequency(str) {
    let freq = {};

    for (let i = 0; i < str.length; i++) {
        let ch = str[i];

        if (freq[ch] === undefined) {
            freq[ch] = 1;
        } else {
            freq[ch]++;
        }
    }

    return freq;
}

//6. Sort Array (Bubble Sort)

function bubbleSort(arr) {
    let n = arr.length;

    for (let i = 0; i < n - 1; i++) {
        for (let j = 0; j < n - 1 - i; j++) {
            if (arr[j] > arr[j + 1]) {
                let temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }

    return arr;
}

//7. Find Second Largest Number

function secondLargest(arr) {
    let first = -Infinity;
    let second = -Infinity;

    for (let i = 0; i < arr.length; i++) {
        if (arr[i] > first) {
            second = first;
            first = arr[i];
        } else if (arr[i] > second && arr[i] !== first) {
            second = arr[i];
        }
    }

    return second;
}

//Find missing number from 1 to N.

function findMissing(arr, n) {
    let total = (n * (n + 1)) / 2;
    let sum = 0;

    for (let i = 0; i < arr.length; i++) {
        sum += arr[i];
    }

    return total - sum;
}


//Check if two strings are anagrams (no sort).
function isAnagram(str1, str2) {
    if (str1.length !== str2.length) return false;

    let count = {};

    for (let i = 0; i < str1.length; i++) {
        let ch = str1[i];
        count[ch] = (count[ch] || 0) + 1;
    }

    for (let i = 0; i < str2.length; i++) {
        let ch = str2[i];
        if (!count[ch]) return false;
        count[ch]--;
    }

    return true;
}

//Move all zeros to end without changing order.

function moveZeros(arr) {
    let index = 0;

    for (let i = 0; i < arr.length; i++) {
        if (arr[i] !== 0) {
            let temp = arr[index];
            arr[index] = arr[i];
            arr[i] = temp;
            index++;
        }
    }

    return arr;
}

