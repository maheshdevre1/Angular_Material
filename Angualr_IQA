  const api2$ = this.http.get('https://api2.example.com');
  forkJoin([api1$, api2$]).subscribe(
    ([response1, response2]) => {
      // Both API responses are available here
      console.log(response1);
      console.log(response2);
    },
    error => {
      console.error('Error fetching data', error);
    }
  );
